{
	"name": "notion-expenses-form",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types --check && vite build",
		"preview": "wrangler pages dev .svelte-kit/cloudflare --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"sveltecheck": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"gen": "wrangler types",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint",
		"fmt": "biome format --write",
		"check": "biome check",
		"fix": "biome check --write",
		"check:all": "bun check && bun typecheck && bun sveltecheck"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^26.0.1",
		"daisyui": "^5.6.3",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"wrangler": "^4.105.0"
	},
	"dependencies": {
		"zod": "^4.4.3"
	}
}
